# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=blockchain_voting_amoy
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# JWT Configuration
JWT_SECRET=change-this-to-a-strong-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email Configuration (Brevo / Sendinblue)
BREVO_API_KEY=your_brevo_api_key_here
BREVO_FROM_EMAIL=noreply@yourdomain.com

# Server Configuration
PORT=5000
NODE_ENV=development

# CORS Configuration
CLIENT_URL=http://localhost:5173

# Blockchain Configuration - Polygon Amoy Testnet
BLOCKCHAIN_NETWORK_URL=https://rpc-amoy.polygon.technology
DEFAULT_GAS_LIMIT=6721975
DEFAULT_GAS_PRICE=35000000000

# Polygon Amoy Network Settings
POLYGON_CHAIN_ID=80002
POLYGON_NETWORK_NAME=Amoy Testnet

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Session Configuration
SESSION_SECRET=change-this-to-a-strong-random-string

# File Upload
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif

# Security
BCRYPT_ROUNDS=12
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10
